#include<iostream>
#include<stack>

using namespace std;

void PrintMiddle(stack<int> &s,int count, int size){
    //base case
    if(count ==  size/2){
        cout<<s.top()<<endl;
        return;
    }
    
    int value = s.top();
    
    s.pop();
    count ++;
    PrintMiddle(s,count,size);
    
    s.push(value);
    
    
}

int main(){
    stack<int> s;
    
    s.push(10);
    s.push(20);
    s.push(30);
    s.push(40);
    s.push(50);
    s.push(60);
    s.push(70);
    
    int size = s.size();
    
    PrintMiddle(s,0,size);
}
